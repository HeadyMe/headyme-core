# HeadyMe — Environment Configuration
# Copy to .env and fill in values for local development.

# Server
PORT=8080
HOST=0.0.0.0
NODE_ENV=development

# Public base URL (no trailing slash)
BASE_URL=https://headyme.com

# CORS — comma-separated allowed origins (defaults to BASE_URL)
# CORS_ORIGINS=https://headyme.com,https://www.headyme.com
